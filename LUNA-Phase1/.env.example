# LUNA Phase 1 — Environment Variables
# Copy this file to .env.local and fill in your actual values

# ── Supabase (get these from your Supabase project → Settings → API) ──
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Google OAuth (from Google Cloud Console → Credentials) ──
VITE_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# ── App Config ──────────────────────────────────────────────
VITE_APP_NAME=LUNA
VITE_APP_URL=https://tryluna.in

# ── Resend (for Partner Bridge emails) ──
# Sign up at resend.com — free tier: 100 emails/day
VITE_RESEND_API_KEY=re_your_resend_key_here
VITE_PARTNER_FROM_EMAIL=care@tryluna.in
